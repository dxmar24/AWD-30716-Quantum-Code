    "var_2b3fe7dd858a": {
      "type": "variant",
      "label": "System Override (Variant 3)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1540,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@300;400;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --ink-black: #010B13;\n    --warning-yellow: #FDEE00;\n    --ash-grey: #B2BEB5;\n  }\n\n  body {\n    background-color: var(--ink-black);\n    color: var(--ash-grey);\n    font-family: 'Space Grotesk', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n  \n  .warning-stripes {\n    background: repeating-linear-gradient(\n      45deg,\n      var(--warning-yellow),\n      var(--warning-yellow) 20px,\n      var(--ink-black) 20px,\n      var(--ink-black) 40px\n    );\n  }\n\n  .duotone-bg {\n    filter: grayscale(100%) contrast(120%) brightness(80%);\n    mix-blend-mode: multiply;\n  }\n\n  .brutalist-card {\n    border: 3px solid var(--ink-black);\n    background-color: var(--ash-grey);\n    box-shadow: 6px 6px 0 var(--warning-yellow);\n    transition: transform 0.1s;\n  }\n\n  .brutalist-card:hover {\n    transform: translate(-2px, -2px);\n    box-shadow: 8px 8px 0 var(--warning-yellow);\n  }\n\n  .marquee-diagonal {\n    transform: rotate(-3deg) scale(1.1);\n  }\n\n  .pixel-corners {\n    clip-path: polygon(\n      0 10px, 10px 10px, 10px 0,\n      calc(100% - 10px) 0, calc(100% - 10px) 10px, 100% 10px,\n      100% calc(100% - 10px), calc(100% - 10px) calc(100% - 10px), calc(100% - 10px) 100%,\n      10px 100%, 10px calc(100% - 10px), 0 calc(100% - 10px)\n    );\n  }\n\n  .glitch-reveal img {\n    filter: blur(20px) brightness(0);\n    transition: filter 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);\n  }\n\n  .glitch-reveal:hover img {\n    filter: blur(0) brightness(1);\n  }\n\n  .scanline {\n    width: 100%;\n    height: 100px;\n    background: linear-gradient(0deg, rgba(253, 238, 0, 0.1) 0%, transparent 100%);\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    animation: scan 4s linear infinite;\n    pointer-events: none;\n    z-index: 50;\n  }\n\n  @keyframes scan {\n    0% { transform: translateY(100vh); }\n    100% { transform: translateY(-100vh); }\n  }\n\n  .terminal-window {\n    border: 4px solid var(--ink-black);\n    background: #111;\n  }\n\n  .terminal-header {\n    background: var(--ink-black);\n    height: 32px;\n    display: flex;\n    align-items: center;\n    padding: 0 12px;\n    gap: 8px;\n  }\n\n  .dot { width: 12px; height: 12px; border-radius: 50%; }\n</style>\n<div class=\"relative\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- Hero Section -->\n    <section class=\"relative h-screen flex items-center justify-center bg-black overflow-hidden\" data-kid=\"1-1\" data-name=\"hero section\">\n        <div class=\"absolute inset-0 z-0\" data-kid=\"1-1-1\" data-name=\"hero background image container\">\n            <img alt=\"Urban Dancer\" class=\"w-full h-full object-cover opacity-50 duotone-bg\" data-kid=\"1-1-1-1\" data-name=\"urban dancer image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1761882612894-f51655cfa6c7?auto=format&w=1600&q=80&fit=crop\"/>\n            <div class=\"absolute inset-0 bg-warning-yellow/20 mix-blend-color\" data-kid=\"1-1-1-2\" data-name=\"hero background overlay\">\n            </div>\n        </div>\n        <div class=\"relative z-10 text-center w-full\" data-kid=\"1-1-2\" data-name=\"hero content wrapper\">\n            <h1 class=\"font-anton text-[25vw] leading-none text-warning-yellow uppercase tracking-tighter mix-blend-difference\" data-kid=\"1-1-2-1\" data-name=\"hero main headline\">\n                MOVE\n            </h1>\n            <p class=\"font-anton text-4xl text-white mt-[-2vw] uppercase mix-blend-difference\" data-kid=\"1-1-2-2\" data-name=\"hero subheading\">\n                American Latin Class // 2026\n            </p>\n        </div>\n        <!-- Diagonal Ticker -->\n        <div class=\"absolute bottom-20 left-[-5%] right-[-5%] z-20 marquee-diagonal\" data-kid=\"1-1-3\" data-name=\"diagonal ticker wrapper\">\n            <div class=\"warning-stripes h-16 flex items-center overflow-hidden border-y-4 border-black\" data-kid=\"1-1-3-1\" data-name=\"marquee stripes container\">\n                <div class=\"whitespace-nowrap font-anton text-2xl px-4 animate-marquee\" data-kid=\"1-1-3-1-1\" data-name=\"scrolling ticker text\">\n                    ENROLLMENT OPEN // SYSTEM STATUS: ACTIVE // NO LIMITS // DANCE OR DIE // ENROLLMENT OPEN // SYSTEM STATUS: ACTIVE // NO LIMITS // DANCE OR DIE //\n                </div>\n            </div>\n        </div>\n        <div class=\"scanline\" data-dynamic=\"true\" data-kid=\"1-1-4\" data-name=\"scanline animation overlay\" data-reason=\"continuous vertical scanline animation\">\n        </div>\n    </section>\n    <!-- Metrics Section -->\n    <section class=\"py-32 px-10 bg-warning-yellow text-ink-black border-y-8 border-black\" data-kid=\"1-2\" data-name=\"metrics section\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-20\" data-kid=\"1-2-1\" data-name=\"metrics grid container\">\n            <div class=\"relative\" data-kid=\"1-2-1-1\" data-name=\"metric card one wrapper\">\n                <span class=\"font-anton text-[200px] leading-none opacity-10 absolute -top-20 -left-10 select-none\" data-kid=\"1-2-1-1-1\" data-name=\"metric index label 01\">\n                    01\n                </span>\n                <div class=\"relative z-10\" data-kid=\"1-2-1-1-2\" data-name=\"metric content container\">\n                    <h2 class=\"font-anton text-8xl uppercase mb-4\" data-kid=\"1-2-1-1-2-1\" data-name=\"metric one heading\">\n                        5 Sedes\n                    </h2>\n                    <p class=\"text-2xl font-bold max-w-md\" data-kid=\"1-2-1-1-2-2\" data-name=\"metric one description\">\n                        Nodes activos en la red metropolitana. Sincronización total.\n                    </p>\n                </div>\n            </div>\n            <div class=\"relative\" data-kid=\"1-2-1-2\" data-name=\"metric card two wrapper\">\n                <span class=\"font-anton text-[200px] leading-none opacity-10 absolute -top-20 -left-10 select-none\" data-kid=\"1-2-1-2-1\" data-name=\"metric index label 02\">\n                    02\n                </span>\n                <div class=\"relative z-10\" data-kid=\"1-2-1-2-2\" data-name=\"metric content container\">\n                    <h2 class=\"font-anton text-8xl uppercase mb-4\" data-kid=\"1-2-1-2-2-1\" data-name=\"metric two heading\">\n                        12+ Estilos\n                    </h2>\n                    <p class=\"text-2xl font-bold max-w-md\" data-kid=\"1-2-1-2-2-2\" data-name=\"metric two description\">\n                        Algoritmos de movimiento desde lo Urbano hasta lo Étnico.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Programs Section -->\n    <section class=\"py-32 px-10 bg-ink-black\" data-kid=\"1-3\" data-name=\"programs section\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"1-3-1\" data-name=\"programs content wrapper\">\n            <h3 class=\"font-anton text-6xl text-warning-yellow uppercase mb-16 underline decoration-8 underline-offset-8\" data-kid=\"1-3-1-1\" data-name=\"programs section title\">\n                Programas.exe\n            </h3>\n            <div class=\"grid grid-cols-4 grid-rows-2 gap-6 h-[800px]\" data-kid=\"1-3-1-2\" data-name=\"programs grid layout\">\n                <!-- Urban -->\n                <div class=\"col-span-2 row-span-2 brutalist-card p-10 flex flex-col justify-between group cursor-pointer\" data-kid=\"1-3-1-2-1\" data-name=\"urban program card\">\n                    <div class=\"flex justify-between items-start\" data-kid=\"1-3-1-2-1-1\" data-name=\"urban card header\">\n                        <h4 class=\"font-anton text-7xl uppercase text-ink-black\" data-kid=\"1-3-1-2-1-1-1\" data-name=\"urban program title\">\n                            Urbano\n                        </h4>\n                        <i class=\"ti ti-arrow-up-right text-5xl text-ink-black group-hover:translate-x-2 group-hover:-translate-y-2 transition-transform\" data-kid=\"1-3-1-2-1-1-2\" data-name=\"urban program arrow icon\">\n                        </i>\n                    </div>\n                    <div class=\"mt-auto\" data-kid=\"1-3-1-2-1-2\" data-name=\"urban card footer\">\n                        <img alt=\"barcode\" class=\"w-32 mb-6\" data-kid=\"1-3-1-2-1-2-1\" data-name=\"urban program barcode icon\" src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/black-bar.svg\"/>\n                        <p class=\"text-xl font-bold text-ink-black\" data-kid=\"1-3-1-2-1-2-2\" data-name=\"urban program description\">\n                            Hip Hop, Heels, Afro & Dancehall. Alta intensidad.\n                        </p>\n                    </div>\n                </div>\n                <!-- Tropical -->\n                <div class=\"col-span-2 row-span-1 bg-ash-grey border-3 border-black shadow-[6px_6px_0_#FDEE00] p-8 flex items-center justify-between group cursor-pointer transition-all hover:bg-warning-yellow\" data-kid=\"1-3-1-2-2\" data-name=\"tropical program card\">\n                    <h4 class=\"font-anton text-5xl uppercase text-ink-black\" data-kid=\"1-3-1-2-2-1\" data-name=\"tropical program title\">\n                        Tropical\n                    </h4>\n                    <div class=\"w-20 h-20 bg-ink-black rounded-full flex items-center justify-center\" data-kid=\"1-3-1-2-2-2\" data-name=\"tropical program icon container\">\n                        <i class=\"ti ti-activity text-warning-yellow text-3xl\" data-kid=\"1-3-1-2-2-2-1\" data-name=\"tropical program activity icon\">\n                        </i>\n                    </div>\n                </div>\n                <!-- Ethnic -->\n                <div class=\"col-span-1 row-span-1 brutalist-card p-8 flex flex-col items-center justify-center text-center cursor-pointer group\" data-kid=\"1-3-1-2-3\" data-name=\"ethnic program card\">\n                    <i class=\"ti ti-globe text-6xl text-ink-black mb-4\" data-kid=\"1-3-1-2-3-1\" data-name=\"ethnic program globe icon\">\n                    </i>\n                    <h4 class=\"font-anton text-2xl uppercase text-ink-black\" data-kid=\"1-3-1-2-3-2\" data-name=\"ethnic program title\">\n                        Étnico\n                    </h4>\n                </div>\n                <!-- Levels -->\n                <div class=\"col-span-1 row-span-1 bg-ink-black border-3 border-warning-yellow p-8 flex flex-col justify-center items-center\" data-kid=\"1-3-1-2-4\" data-name=\"levels info card\">\n                    <span class=\"text-warning-yellow font-anton text-5xl uppercase\" data-kid=\"1-3-1-2-4-1\" data-name=\"levels range text\">\n                        B1 // B2\n                    </span>\n                    <span class=\"text-ash-grey uppercase text-xs tracking-widest mt-2\" data-kid=\"1-3-1-2-4-2\" data-name=\"levels access label\">\n                        Acceso de Nivel\n                    </span>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Branches / Hover Preview -->\n    <section class=\"flex flex-col md:flex-row h-screen border-t-8 border-black\" data-kid=\"1-4\" data-name=\"branches and hover preview section\">\n        <div class=\"md:w-1/2 bg-ink-black p-20 flex flex-col justify-center gap-12\" data-kid=\"1-4-1\" data-name=\"branches list container\">\n            <h3 class=\"font-anton text-3xl text-warning-yellow uppercase tracking-widest mb-10\" data-kid=\"1-4-1-1\" data-name=\"branches title\">\n                // SEDES_SCAN\n            </h3>\n            <div class=\"flex flex-col gap-4\" data-kid=\"1-4-1-2\" data-name=\"branches navigation list\">\n                <button class=\"font-anton text-8xl text-left uppercase text-ash-grey hover:text-warning-yellow hover:pl-10 transition-all glitch-reveal\" data-kid=\"1-4-1-2-1\" data-name=\"matrix branch button\">\n                    Matriz\n                </button>\n                <button class=\"font-anton text-8xl text-left uppercase text-ash-grey hover:text-warning-yellow hover:pl-10 transition-all glitch-reveal\" data-kid=\"1-4-1-2-2\" data-name=\"norte branch button\">\n                    Norte\n                </button>\n                <button class=\"font-anton text-8xl text-left uppercase text-ash-grey hover:text-warning-yellow hover:pl-10 transition-all glitch-reveal\" data-kid=\"1-4-1-2-3\" data-name=\"sur guamaní branch button\">\n                    Sur Guamaní\n                </button>\n                <button class=\"font-anton text-8xl text-left uppercase text-ash-grey hover:text-warning-yellow hover:pl-10 transition-all glitch-reveal\" data-kid=\"1-4-1-2-4\" data-name=\"tumbaco branch button\">\n                    Tumbaco\n                </button>\n            </div>\n        </div>\n        <div class=\"md:w-1/2 bg-warning-yellow relative overflow-hidden flex items-center justify-center\" data-kid=\"1-4-2\" data-name=\"branch preview image container\">\n            <img alt=\"Sede Preview\" class=\"w-full h-full object-cover grayscale contrast-150 mix-blend-multiply opacity-80\" data-kid=\"1-4-2-1\" data-name=\"branch preview image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/15558248/pexels-photo-15558248.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\"/>\n            <div class=\"absolute inset-0 border-[20px] border-ink-black\" data-kid=\"1-4-2-2\" data-name=\"preview border overlay\">\n            </div>\n            <div class=\"font-anton text-4xl text-ink-black bg-warning-yellow px-4 absolute top-10 left-10\" data-kid=\"1-4-2-3\" data-name=\"preview location ID badge\">\n                LOC_ID: 593-QUI\n            </div>\n        </div>\n    </section>\n    <!-- Enrollment Terminal -->\n    <section class=\"py-32 px-10 bg-ash-grey\" data-kid=\"1-5\" data-name=\"enrollment terminal section\">\n        <div class=\"max-w-4xl mx-auto terminal-window shadow-[20px_20px_0_rgba(0,0,0,0.8)]\" data-kid=\"1-5-1\" data-name=\"terminal window container\">\n            <div class=\"terminal-header\" data-kid=\"1-5-1-1\" data-name=\"terminal header bar\">\n                <div class=\"dot bg-red-500\" data-kid=\"1-5-1-1-1\" data-name=\"terminal red dot\">\n                </div>\n                <div class=\"dot bg-yellow-500\" data-kid=\"1-5-1-1-2\" data-name=\"terminal yellow dot\">\n                </div>\n                <div class=\"dot bg-green-500\" data-kid=\"1-5-1-1-3\" data-name=\"terminal green dot\">\n                </div>\n                <span class=\"ml-4 font-mono text-xs text-ash-grey/50\" data-kid=\"1-5-1-1-4\" data-name=\"terminal file path text\">\n                    root@alc-system:~/enrollment\n                </span>\n            </div>\n            <div class=\"p-12\" data-kid=\"1-5-1-2\" data-name=\"terminal content wrapper\">\n                <h2 class=\"font-anton text-5xl text-warning-yellow uppercase mb-8\" data-kid=\"1-5-1-2-1\" data-name=\"enrollment heading\">\n                    Inicializar Inscripción\n                </h2>\n                <form class=\"grid grid-cols-1 gap-6\" data-kid=\"1-5-1-2-2\" data-name=\"enrollment form\">\n                    <div data-kid=\"1-5-1-2-2-1\" data-name=\"identity input field group\">\n                        <label class=\"font-anton uppercase text-warning-yellow text-xl mb-2 block\" data-kid=\"1-5-1-2-2-1-1\" data-name=\"identity label\">\n                            > IDENTIDAD_USUARIO\n                        </label>\n                        <input class=\"w-full bg-transparent border-4 border-warning-yellow p-4 font-anton text-2xl text-white focus:bg-warning-yellow focus:text-ink-black outline-none transition-colors\" data-kid=\"1-5-1-2-2-1-2\" data-name=\"identity text input\" placeholder=\"Nombre completo...\" type=\"text\"/>\n                    </div>\n                    <div data-kid=\"1-5-1-2-2-2\" data-name=\"communication link input field group\">\n                        <label class=\"font-anton uppercase text-warning-yellow text-xl mb-2 block\" data-kid=\"1-5-1-2-2-2-1\" data-name=\"communication link label\">\n                            > COM_LINK\n                        </label>\n                        <input class=\"w-full bg-transparent border-4 border-warning-yellow p-4 font-anton text-2xl text-white focus:bg-warning-yellow focus:text-ink-black outline-none transition-colors\" data-kid=\"1-5-1-2-2-2-2\" data-name=\"communication link email input\" placeholder=\"Correo electrónico...\" type=\"email\"/>\n                    </div>\n                    <div class=\"grid grid-cols-2 gap-6\" data-kid=\"1-5-1-2-2-3\" data-name=\"selection inputs group\">\n                        <div data-kid=\"1-5-1-2-2-3-1\" data-name=\"sector selection group\">\n                            <label class=\"font-anton uppercase text-warning-yellow text-xl mb-2 block\" data-kid=\"1-5-1-2-2-3-1-1\" data-name=\"sector label\">\n                                > SECTOR_SELEC\n                            </label>\n                            <select class=\"w-full bg-transparent border-4 border-warning-yellow p-4 font-anton text-2xl text-white focus:bg-warning-yellow focus:text-ink-black outline-none appearance-none cursor-pointer\" data-kid=\"1-5-1-2-2-3-1-2\" data-name=\"sector select dropdown\">\n                                <option data-kid=\"1-5-1-2-2-3-1-2-1\" data-name=\"sector option matrix\">\n                                    Matriz\n                                </option>\n                                <option data-kid=\"1-5-1-2-2-3-1-2-2\" data-name=\"sector option norte\">\n                                    Norte\n                                </option>\n                            </select>\n                        </div>\n                        <div data-kid=\"1-5-1-2-2-3-2\" data-name=\"dance protocol group\">\n                            <label class=\"font-anton uppercase text-warning-yellow text-xl mb-2 block\" data-kid=\"1-5-1-2-2-3-2-1\" data-name=\"protocol label\">\n                                > PROTOCOLO_DANCE\n                            </label>\n                            <input class=\"w-full bg-transparent border-4 border-warning-yellow p-4 font-anton text-2xl text-white focus:bg-warning-yellow focus:text-ink-black outline-none transition-colors\" data-kid=\"1-5-1-2-2-3-2-2\" data-name=\"protocol text input\" placeholder=\"Salsa, Hip Hop...\" type=\"text\"/>\n                        </div>\n                    </div>\n                    <button class=\"mt-8 bg-warning-yellow text-ink-black font-anton text-4xl p-6 uppercase hover:bg-white transition-colors border-4 border-ink-black pixel-corners\" data-kid=\"1-5-1-2-2-4\" data-name=\"submit execution button\" type=\"submit\">\n                        EJECUTAR_SOLICITUD\n                    </button>\n                </form>\n            </div>\n        </div>\n    </section>\n    <!-- Footer -->\n    <footer class=\"bg-ink-black p-10 border-t-4 border-warning-yellow\" data-kid=\"1-6\" data-name=\"footer\">\n        <div class=\"max-w-7xl mx-auto flex justify-between items-center\" data-kid=\"1-6-1\" data-name=\"footer container\">\n            <div class=\"font-anton text-3xl text-warning-yellow\" data-kid=\"1-6-1-1\" data-name=\"footer logo text\">\n                ALC_CORE\n            </div>\n            <div class=\"font-mono text-xs uppercase tracking-widest text-ash-grey\" data-kid=\"1-6-1-2\" data-name=\"footer copyright info\">\n                © 2026 American Latin Class // Encryption: AES-256\n            </div>\n        </div>\n    </footer>\n</div>\n<script>\n    // Simple marquee logic or just CSS\n</script>\n",
