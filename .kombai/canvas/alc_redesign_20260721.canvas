      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&family=Fira+Sans:wght@300;400;700;900&family=Fira+Mono&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --onyx: #111111;\n    --alabaster: #E5E4E2;\n    --neon-yellow: #FDEE00;\n    --dark-grey: #1A1A1A;\n    --panel-border: rgba(229, 228, 226, 0.1);\n  }\n\n  body {\n    margin: 0;\n    background-color: var(--onyx);\n    color: var(--alabaster);\n    font-family: 'Fira Sans', sans-serif;\n    overflow-x: hidden;\n  }\n\n  .font-space { font-family: 'Space Grotesk', sans-serif; }\n  .font-mono { font-family: 'Fira Mono', monospace; }\n\n  .chamfer {\n    clip-path: polygon(12px 0, calc(100% - 12px) 0, 100% 12px, 100% calc(100% - 12px), calc(100% - 12px) 100%, 12px 100%, 0 calc(100% - 12px), 0 12px);\n  }\n\n  .cut-corner-br {\n    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 40px), calc(100% - 40px) 100%, 0 100%);\n  }\n\n  .cut-corner-tl {\n    clip-path: polygon(40px 0, 100% 0, 100% 100%, 0 100%, 0 40px);\n  }\n\n  .scanning-line::after {\n    content: \"\";\n    position: absolute;\n    top: 0;\n    left: 0;\n    width: 100%;\n    height: 2px;\n    background: linear-gradient(90deg, transparent, var(--neon-yellow), transparent);\n    animation: scan 4s linear infinite;\n    z-index: 10;\n    opacity: 0.5;\n  }\n\n  @keyframes scan {\n    0% { top: 0; }\n    100% { top: 100%; }\n  }\n\n  .glow-yellow {\n    box-shadow: 0 0 15px rgba(253, 238, 0, 0.3);\n  }\n\n  .circuit-line {\n    background: var(--neon-yellow);\n    box-shadow: 0 0 8px var(--neon-yellow);\n  }\n\n  .ripple {\n    animation: ripple-effect 2s infinite;\n  }\n\n  @keyframes ripple-effect {\n    0% { transform: scale(1); opacity: 0.8; }\n    100% { transform: scale(3); opacity: 0; }\n  }\n\n  .marquee-vertical {\n    animation: marquee-v 20s linear infinite;\n  }\n\n  @keyframes marquee-v {\n    0% { transform: translateY(0); }\n    100% { transform: translateY(-50%); }\n  }\n\n  .hud-frame {\n    position: relative;\n    border: 1px solid var(--panel-border);\n  }\n\n  .hud-frame::before {\n    content: \"\";\n    position: absolute;\n    top: -1px;\n    left: -1px;\n    width: 20px;\n    height: 20px;\n    border-top: 2px solid var(--neon-yellow);\n    border-left: 2px solid var(--neon-yellow);\n  }\n\n  .hud-frame::after {\n    content: \"\";\n    position: absolute;\n    bottom: -1px;\n    right: -1px;\n    width: 20px;\n    height: 20px;\n    border-bottom: 2px solid var(--neon-yellow);\n    border-right: 2px solid var(--neon-yellow);\n  }\n</style>\n<div class=\"min-h-screen flex flex-col\" data-kid=\"1\">\n    <!-- Nav -->\n    <nav class=\"fixed top-0 w-full z-50 bg-[#111111]/80 backdrop-blur-md border-b border-white/5\" data-kid=\"1-1\">\n        <div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\" data-kid=\"1-1-1\">\n            <div class=\"flex items-center gap-4\" data-kid=\"1-1-1-1\">\n                <div class=\"w-10 h-10 border border-[#FDEE00] flex items-center justify-center bg-[#FDEE00]/10 chamfer\" data-kid=\"1-1-1-1-1\">\n                    <span class=\"text-[#FDEE00] font-black text-xs\" data-kid=\"1-1-1-1-1-1\">\n                        ALC\n                    </span>\n                </div>\n                <span class=\"font-space font-bold tracking-tighter text-xl uppercase\" data-kid=\"1-1-1-1-2\">\n                    American Latin Class\n                </span>\n            </div>\n            <div class=\"hidden md:flex items-center gap-8 text-sm font-bold uppercase tracking-widest text-white/60\" data-kid=\"1-1-1-2\">\n                <a class=\"hover:text-[#FDEE00] transition-colors\" data-kid=\"1-1-1-2-1\" href=\"#programs\">\n                    Programas\n                </a>\n                <a class=\"hover:text-[#FDEE00] transition-colors\" data-kid=\"1-1-1-2-2\" href=\"#branches\">\n                    Sedes\n                </a>\n                <a class=\"px-6 py-2 border border-[#FDEE00] text-[#FDEE00] chamfer hover:bg-[#FDEE00] hover:text-black transition-all\" data-kid=\"1-1-1-2-3\" href=\"/login.html\">\n                    Acceso Grid\n                </a>\n            </div>\n        </div>\n    </nav>\n    <!-- Hero Section -->\n    <section class=\"relative h-screen flex overflow-hidden pt-20\" data-kid=\"1-2\">\n        <!-- Left Rail -->\n        <div class=\"w-20 bg-[#0A0A0A] border-r border-white/5 flex flex-col items-center py-10 relative overflow-hidden\" data-kid=\"1-2-1\">\n            <div class=\"marquee-vertical flex flex-col gap-12 whitespace-nowrap\" data-kid=\"1-2-1-1\" data-name=\"marquee text list container\">\n                <span class=\"rotate-90 text-[10px] font-mono text-white/20 uppercase tracking-[0.5em]\" data-kid=\"1-2-1-1-1\" data-name=\"first marquee status line\">\n                    System.Status.Active // Node.Synchronization.In.Progress // Data.Stream.Latency.Low\n                </span>\n                <span class=\"rotate-90 text-[10px] font-mono text-white/20 uppercase tracking-[0.5em]\" data-kid=\"1-2-1-1-2\" data-name=\"second marquee status line\">\n                    System.Status.Active // Node.Synchronization.In.Progress // Data.Stream.Latency.Low\n                </span>\n            </div>\n        </div>\n        <!-- Main Hero -->\n        <div class=\"flex-1 grid grid-cols-1 lg:grid-cols-12 relative\" data-kid=\"1-2-2\">\n            <div class=\"lg:col-span-7 flex flex-col justify-center px-12 lg:px-24 z-10 bg-gradient-to-r from-[#111111] via-[#111111] to-transparent\" data-kid=\"1-2-2-1\">\n                <div class=\"inline-flex items-center gap-2 text-[#FDEE00] mb-6\" data-kid=\"1-2-2-1-1\">\n                    <div class=\"w-2 h-2 bg-[#FDEE00] rounded-full animate-pulse\" data-kid=\"1-2-2-1-1-1\" data-name=\"hero status pulsing indicator\">\n                    </div>\n                    <span class=\"text-xs font-mono uppercase tracking-[0.3em]\" data-kid=\"1-2-2-1-1-2\" data-name=\"hero status label\">\n                        Protocolo de Movimiento v4.2\n                    </span>\n                </div>\n                <h1 class=\"text-7xl lg:text-9xl font-space font-black leading-none tracking-tighter uppercase mb-8\" data-kid=\"1-2-2-1-2\">\n                    Move with\n                    <br data-kid=\"1-2-2-1-2-1\"/>\n                    <span class=\"text-transparent\" data-kid=\"1-2-2-1-2-2\" style=\"-webkit-text-stroke: 1px var(--alabaster);\">\n                        Purpose\n                    </span>\n                </h1>\n                <p class=\"max-w-xl text-lg text-white/60 mb-10 leading-relaxed\" data-kid=\"1-2-2-1-3\">\n                    Centralizamos el ritmo y la técnica. Gestión académica para bailarines urbanos, tropicales y étnicos bajo un mismo sistema de control.\n                </p>\n                <div class=\"flex flex-wrap gap-6\" data-kid=\"1-2-2-1-4\">\n                    <a class=\"px-10 py-4 bg-[#FDEE00] text-black font-black uppercase tracking-widest text-sm chamfer hover:scale-105 transition-transform glow-yellow\" data-kid=\"1-2-2-1-4-1\" href=\"#enroll\">\n                        Inicializar Inscripción\n                    </a>\n                    <a class=\"px-10 py-4 border border-white/20 text-white font-bold uppercase tracking-widest text-sm chamfer hover:bg-white/5 transition-all\" data-kid=\"1-2-2-1-4-2\" href=\"#programs\">\n                        Explorar Red\n                    </a>\n                </div>\n            </div>\n            <!-- Hero Image -->\n            <div class=\"absolute right-0 top-0 w-1/2 h-full lg:col-span-5 lg:relative lg:w-full overflow-hidden scanning-line\" data-kid=\"1-2-2-2\" data-name=\"hero image scanning container\">\n                <img alt=\"Urban dancer caught mid-air with underlit yellow neon lights\" class=\"w-full h-full object-cover grayscale contrast-125\" data-kid=\"1-2-2-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/19458616/pexels-photo-19458616.jpeg?auto=compress&cs=tinysrgb&w=1440&q=80\"/>\n                <div class=\"absolute inset-0 bg-[#FDEE00]/10 mix-blend-color\" data-kid=\"1-2-2-2-2\">\n                </div>\n                <div class=\"absolute inset-0 bg-gradient-to-t from-[#111111] via-transparent to-transparent\" data-kid=\"1-2-2-2-3\">\n                </div>\n                <div class=\"absolute inset-0 bg-gradient-to-r from-[#111111] via-transparent to-transparent\" data-kid=\"1-2-2-2-4\">\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Metrics Sentence Section -->\n    <section class=\"py-32 bg-[#161616] relative border-y border-white/5 overflow-hidden\" data-kid=\"1-3\">\n        <!-- Topographic Background -->\n        <svg class=\"absolute inset-0 w-full h-full opacity-5\" data-kid=\"1-3-1\" preserveaspectratio=\"xMidYMid slice\" viewbox=\"0 0 1000 1000\">\n            <path d=\"M0,500 C100,450 200,550 300,500 S500,450 600,500 S800,550 1000,500\" fill=\"none\" stroke=\"white\" stroke-width=\"1\">\n            </path>\n            <path d=\"M0,600 C100,550 200,650 300,600 S500,550 600,600 S800,650 1000,600\" fill=\"none\" stroke=\"white\" stroke-width=\"1\">\n            </path>\n            <path d=\"M0,400 C100,350 200,450 300,400 S500,350 600,400 S800,450 1000,400\" fill=\"none\" stroke=\"white\" stroke-width=\"1\">\n            </path>\n        </svg>\n        <div class=\"max-w-5xl mx-auto px-6 text-center relative z-10\" data-kid=\"1-3-2\">\n            <p class=\"text-3xl lg:text-5xl font-space font-light leading-[1.4] text-white/40\" data-kid=\"1-3-2-1\">\n                Empoderando\n                <span class=\"text-[#FDEE00] font-black italic\" data-kid=\"1-3-2-1-1\">\n                    5\n                </span>\n                grid-nodes activos, operando bajo\n                <span class=\"text-[#FDEE00] font-black italic\" data-kid=\"1-3-2-1-2\">\n                    3\n                </span>\n                líneas core con más de\n                <span class=\"text-[#FDEE00] font-black italic\" data-kid=\"1-3-2-1-3\">\n                    12\n                </span>\n                estilos sincronizados en tiempo real.\n            </p>\n        </div>\n    </section>\n    <!-- Programs Zigzag Section -->\n    <section class=\"py-40 relative\" data-kid=\"1-4\" id=\"programs\">\n        <div class=\"max-w-7xl mx-auto px-6 relative\" data-kid=\"1-4-1\">\n            <div class=\"text-center mb-32\" data-kid=\"1-4-1-1\">\n                <h2 class=\"text-4xl lg:text-6xl font-space font-black uppercase tracking-tighter mb-4\" data-kid=\"1-4-1-1-1\">\n                    Directorio de Protocolos\n                </h2>\n                <p class=\"text-white/40 font-mono text-sm uppercase tracking-widest\" data-kid=\"1-4-1-1-2\">\n                    Selecciona una línea de entrenamiento para desplegar detalles\n                </p>\n            </div>\n            <!-- Vertical Connector Line -->\n            <div class=\"absolute left-1/2 top-[400px] bottom-40 w-px bg-white/10 hidden lg:block\" data-kid=\"1-4-1-2\">\n                <div class=\"absolute top-0 left-[-4px] w-2 h-2 rounded-full bg-[#FDEE00] glow-yellow\" data-kid=\"1-4-1-2-1\">\n                </div>\n            </div>\n            <div class=\"space-y-40\" data-kid=\"1-4-1-3\">\n                <!-- Program 1 (Left) -->\n                <div class=\"flex flex-col lg:flex-row items-center gap-12 lg:gap-24\" data-kid=\"1-4-1-3-1\">\n                    <div class=\"lg:w-1/2 order-2 lg:order-1 lg:text-right group\" data-kid=\"1-4-1-3-1-1\">\n                        <div class=\"inline-block px-4 py-1 bg-white/5 border border-white/10 text-white/40 text-xs font-mono mb-4 chamfer\" data-kid=\"1-4-1-3-1-1-1\">\n                            TROPICAL_SYS.EXE\n                        </div>\n                        <h3 class=\"text-4xl font-space font-black uppercase mb-4 group-hover:text-[#FDEE00] transition-colors\" data-kid=\"1-4-1-3-1-1-2\">\n                            Salsa & Bachata\n                        </h3>\n                        <p class=\"text-white/60 leading-relaxed mb-6\" data-kid=\"1-4-1-3-1-1-3\">\n                            Ritmo, coordinación y musicalidad. Trabajo en pareja enfocado en conexión y secuencias sociales.\n                        </p>\n                        <a class=\"text-[#FDEE00] font-bold uppercase tracking-widest text-xs flex items-center lg:justify-end gap-2 group-hover:gap-4 transition-all\" data-kid=\"1-4-1-3-1-1-4\" href=\"#enroll\">\n                            Consultar Parámetros\n                            <i class=\"ti ti-arrow-right\" data-kid=\"1-4-1-3-1-1-4-1\">\n                            </i>\n                        </a>\n                    </div>\n                    <div class=\"lg:w-1/2 order-1 lg:order-2 relative\" data-kid=\"1-4-1-3-1-2\">\n                        <!-- Circuit Trace -->\n                        <div class=\"absolute top-1/2 right-full w-24 h-px bg-[#FDEE00]/30 hidden lg:block\" data-kid=\"1-4-1-3-1-2-1\">\n                            <div class=\"absolute right-0 top-0 w-2 h-2 bg-[#FDEE00] rounded-full glow-yellow\" data-kid=\"1-4-1-3-1-2-1-1\">\n                            </div>\n                        </div>\n                        <div class=\"aspect-video w-full overflow-hidden bg-[#1A1A1A] border border-white/10 chamfer relative\" data-kid=\"1-4-1-3-1-2-2\">\n                            <img alt=\"Salsa\" class=\"w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity\" data-kid=\"1-4-1-3-1-2-2-1\" src=\"/api/local/images/06Code/public/assets/program-salsa.jpg\"/>\n                            <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 to-transparent\" data-kid=\"1-4-1-3-1-2-2-2\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <!-- Program 2 (Right) -->\n                <div class=\"flex flex-col lg:flex-row items-center gap-12 lg:gap-24\" data-kid=\"1-4-1-3-2\">\n                    <div class=\"lg:w-1/2 relative\" data-kid=\"1-4-1-3-2-1\">\n                        <!-- Circuit Trace -->\n                        <div class=\"absolute top-1/2 left-full w-24 h-px bg-[#FDEE00]/30 hidden lg:block\" data-kid=\"1-4-1-3-2-1-1\">\n                            <div class=\"absolute left-0 top-0 w-2 h-2 bg-[#FDEE00] rounded-full glow-yellow\" data-kid=\"1-4-1-3-2-1-1-1\">\n                            </div>\n                        </div>\n                        <div class=\"aspect-video w-full overflow-hidden bg-[#1A1A1A] border border-white/10 chamfer relative\" data-kid=\"1-4-1-3-2-1-2\">\n                            <img alt=\"Hip Hop\" class=\"w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity\" data-kid=\"1-4-1-3-2-1-2-1\" src=\"/api/local/images/06Code/public/assets/program-hiphop.jpg\"/>\n                            <div class=\"absolute inset-0 bg-gradient-to-t from-black/80 to-transparent\" data-kid=\"1-4-1-3-2-1-2-2\">\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"lg:w-1/2 group\" data-kid=\"1-4-1-3-2-2\">\n                        <div class=\"inline-block px-4 py-1 bg-white/5 border border-white/10 text-white/40 text-xs font-mono mb-4 chamfer\" data-kid=\"1-4-1-3-2-2-1\">\n                            URBAN_GRID.EXE\n                        </div>\n                        <h3 class=\"text-4xl font-space font-black uppercase mb-4 group-hover:text-[#FDEE00] transition-colors\" data-kid=\"1-4-1-3-2-2-2\">\n                            Hip Hop & Heels\n                        </h3>\n                        <p class=\"text-white/60 leading-relaxed mb-6\" data-kid=\"1-4-1-3-2-2-3\">\n                            Grooves, coreografía y presencia escénica. Entrenamiento físico intenso con enfoque en actitud y líneas corporales.\n                        </p>\n                        <a class=\"text-[#FDEE00] font-bold uppercase tracking-widest text-xs flex items-center gap-2 group-hover:gap-4 transition-all\" data-kid=\"1-4-1-3-2-2-4\" href=\"#enroll\">\n                            Consultar Parámetros\n                            <i class=\"ti ti-arrow-right\" data-kid=\"1-4-1-3-2-2-4-1\">\n                            </i>\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Branches Map Section -->\n    <section class=\"py-40 bg-[#0A0A0A] border-t border-white/5\" data-kid=\"1-5\" id=\"branches\">\n        <div class=\"max-w-7xl mx-auto px-6 flex flex-col lg:flex-row gap-20\" data-kid=\"1-5-1\">\n            <div class=\"lg:w-2/3 relative h-[600px] bg-[#111111] border border-white/5 chamfer overflow-hidden\" data-kid=\"1-5-1-1\">\n                <!-- Abstract City Grid Overlay -->\n                <div class=\"absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"1-5-1-1-1\" style=\"background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 30px 30px;\">\n                </div>\n                <!-- Ripple Nodes -->\n                <div class=\"absolute top-[20%] left-[30%] group cursor-pointer\" data-kid=\"1-5-1-1-2\">\n                    <div class=\"w-4 h-4 bg-[#FDEE00] rounded-full relative z-10\" data-kid=\"1-5-1-1-2-1\">\n                    </div>\n                    <div class=\"absolute inset-[-10px] border border-[#FDEE00] rounded-full ripple\" data-kid=\"1-5-1-1-2-2\" data-name=\"first map node ripple effect\">\n                    </div>\n                    <div class=\"absolute inset-[-20px] border border-[#FDEE00]/50 rounded-full ripple\" data-kid=\"1-5-1-1-2-3\" data-name=\"first map node outer ripple effect\" style=\"animation-delay: 0.5s;\">\n                    </div>\n                    <div class=\"absolute bottom-full left-1/2 -translate-x-1/2 mb-4 bg-black/90 border border-[#FDEE00] px-3 py-1 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"1-5-1-1-2-4\">\n                        <span class=\"text-[10px] font-mono text-[#FDEE00]\" data-kid=\"1-5-1-1-2-4-1\">\n                            MATRIZ_SECTOR_01\n                        </span>\n                    </div>\n                </div>\n                <div class=\"absolute top-[45%] left-[65%] group cursor-pointer\" data-kid=\"1-5-1-1-3\">\n                    <div class=\"w-4 h-4 bg-[#FDEE00] rounded-full relative z-10\" data-kid=\"1-5-1-1-3-1\">\n                    </div>\n                    <div class=\"absolute inset-[-10px] border border-[#FDEE00] rounded-full ripple\" data-kid=\"1-5-1-1-3-2\" data-name=\"second map node ripple effect\">\n                    </div>\n                    <div class=\"absolute bottom-full left-1/2 -translate-x-1/2 mb-4 bg-black/90 border border-[#FDEE00] px-3 py-1 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"1-5-1-1-3-3\">\n                        <span class=\"text-[10px] font-mono text-[#FDEE00]\" data-kid=\"1-5-1-1-3-3-1\">\n                            NORTE_SECTOR_02\n                        </span>\n                    </div>\n                </div>\n                <div class=\"absolute bottom-[30%] left-[40%] group cursor-pointer\" data-kid=\"1-5-1-1-4\">\n                    <div class=\"w-4 h-4 bg-[#FDEE00] rounded-full relative z-10\" data-kid=\"1-5-1-1-4-1\">\n                    </div>\n                    <div class=\"absolute inset-[-10px] border border-[#FDEE00] rounded-full ripple\" data-kid=\"1-5-1-1-4-2\" data-name=\"third map node ripple effect\">\n                    </div>\n                    <div class=\"absolute bottom-full left-1/2 -translate-x-1/2 mb-4 bg-black/90 border border-[#FDEE00] px-3 py-1 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"1-5-1-1-4-3\">\n                        <span class=\"text-[10px] font-mono text-[#FDEE00]\" data-kid=\"1-5-1-1-4-3-1\">\n                            SUR_SECTOR_03\n                        </span>\n                    </div>\n                </div>\n                <div class=\"absolute bottom-6 left-6 font-mono text-[10px] text-white/20\" data-kid=\"1-5-1-1-5\">\n                    MAP_COORDINATES: -0.1807, -78.4678 // QUITO_METRO_GRID\n                </div>\n            </div>\n            <div class=\"lg:w-1/3 flex flex-col justify-center\" data-kid=\"1-5-1-2\">\n                <h2 class=\"text-4xl font-space font-black uppercase mb-8\" data-kid=\"1-5-1-2-1\">\n                    Nodos de Red\n                </h2>\n                <div class=\"space-y-6\" data-kid=\"1-5-1-2-2\">\n                    <div class=\"p-6 bg-white/5 border-l-4 border-[#FDEE00] chamfer\" data-kid=\"1-5-1-2-2-1\">\n                        <h4 class=\"font-bold text-[#FDEE00] mb-1\" data-kid=\"1-5-1-2-2-1-1\">\n                            MATRIZ_HQ\n                        </h4>\n                        <p class=\"text-xs text-white/60 uppercase tracking-widest mb-2\" data-kid=\"1-5-1-2-2-1-2\">\n                            Punto central de operaciones\n                        </p>\n                        <p class=\"text-sm\" data-kid=\"1-5-1-2-2-1-3\">\n                            Ubicación primaria para procesos de alta continuidad y grupos activos.\n                        </p>\n                    </div>\n                    <div class=\"p-6 border border-white/10 chamfer opacity-40 hover:opacity-100 transition-opacity cursor-pointer\" data-kid=\"1-5-1-2-2-2\">\n                        <h4 class=\"font-bold mb-1\" data-kid=\"1-5-1-2-2-2-1\">\n                            NORTE_NODE\n                        </h4>\n                        <p class=\"text-xs text-white/40 uppercase tracking-widest mb-2\" data-kid=\"1-5-1-2-2-2-2\">\n                            Entrenamiento cercano\n                        </p>\n                    </div>\n                    <div class=\"p-6 border border-white/10 chamfer opacity-40 hover:opacity-100 transition-opacity cursor-pointer\" data-kid=\"1-5-1-2-2-3\">\n                        <h4 class=\"font-bold mb-1\" data-kid=\"1-5-1-2-2-3-1\">\n                            SUR_GUAMANÍ_LINK\n                        </h4>\n                        <p class=\"text-xs text-white/40 uppercase tracking-widest mb-2\" data-kid=\"1-5-1-2-2-3-2\">\n                            Movimiento periférico\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Enrollment HUD Form -->\n    <section class=\"py-40 relative\" data-kid=\"1-6\" id=\"enroll\">\n        <div class=\"max-w-6xl mx-auto px-6\" data-kid=\"1-6-1\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 bg-[#1A1A1A] chamfer hud-frame overflow-hidden\" data-kid=\"1-6-1-1\">\n                <div class=\"p-12 lg:p-20 relative\" data-kid=\"1-6-1-1-1\">\n                    <div class=\"relative z-10\" data-kid=\"1-6-1-1-1-1\">\n                        <h2 class=\"text-4xl lg:text-5xl font-space font-black uppercase mb-6 leading-none\" data-kid=\"1-6-1-1-1-1-1\">\n                            Únete a la\n                            <br data-kid=\"1-6-1-1-1-1-1-1\"/>\n                            <span class=\"text-[#FDEE00]\" data-kid=\"1-6-1-1-1-1-1-2\">\n                                Sincronización\n                            </span>\n                        </h2>\n                        <p class=\"text-white/60 mb-12\" data-kid=\"1-6-1-1-1-1-2\">\n                            Ingresa tus credenciales para ser asignado a un sector y nivel de entrenamiento.\n                        </p>\n                        <form class=\"space-y-6\" data-kid=\"1-6-1-1-1-1-3\">\n                            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"1-6-1-1-1-1-3-1\">\n                                <div class=\"space-y-2\" data-kid=\"1-6-1-1-1-1-3-1-1\">\n                                    <label class=\"text-[10px] font-mono text-white/40 uppercase tracking-widest\" data-kid=\"1-6-1-1-1-1-3-1-1-1\">\n                                        Identificación_Usuario\n                                    </label>\n                                    <input class=\"w-full bg-black/50 border border-white/10 px-4 py-3 text-sm focus:border-[#FDEE00] outline-none transition-all chamfer\" data-kid=\"1-6-1-1-1-1-3-1-1-2\" placeholder=\"NOMBRE COMPLETO\" type=\"text\"/>\n                                </div>\n                                <div class=\"space-y-2\" data-kid=\"1-6-1-1-1-1-3-1-2\">\n                                    <label class=\"text-[10px] font-mono text-white/40 uppercase tracking-widest\" data-kid=\"1-6-1-1-1-1-3-1-2-1\">\n                                        Protocolo_Comunicación\n                                    </label>\n                                    <input class=\"w-full bg-black/50 border border-white/10 px-4 py-3 text-sm focus:border-[#FDEE00] outline-none transition-all chamfer\" data-kid=\"1-6-1-1-1-1-3-1-2-2\" placeholder=\"EMAIL_ADDR\" type=\"email\"/>\n                                </div>\n                            </div>\n                            <div class=\"space-y-2\" data-kid=\"1-6-1-1-1-1-3-2\">\n                                <label class=\"text-[10px] font-mono text-white/40 uppercase tracking-widest\" data-kid=\"1-6-1-1-1-1-3-2-1\">\n                                    Selección_de_Sector\n                                </label>\n                                <select class=\"w-full bg-black/50 border border-white/10 px-4 py-3 text-sm focus:border-[#FDEE00] outline-none transition-all chamfer appearance-none\" data-kid=\"1-6-1-1-1-1-3-2-2\">\n                                    <option data-kid=\"1-6-1-1-1-1-3-2-2-1\">\n                                        MATRIZ_HQ\n                                    </option>\n                                    <option data-kid=\"1-6-1-1-1-1-3-2-2-2\">\n                                        NORTE_NODE\n                                    </option>\n                                    <option data-kid=\"1-6-1-1-1-1-3-2-2-3\">\n                                        SUR_GUAMANÍ_LINK\n                                    </option>\n                                    <option data-kid=\"1-6-1-1-1-1-3-2-2-4\">\n                                        TUMBACO_ACCESS\n                                    </option>\n                                    <option data-kid=\"1-6-1-1-1-1-3-2-2-5\">\n                                        CONOCOTO_POINT\n                                    </option>\n                                </select>\n                            </div>\n                            <div class=\"pt-6\" data-kid=\"1-6-1-1-1-1-3-3\">\n                                <button class=\"w-full py-4 bg-[#FDEE00] text-black font-black uppercase tracking-[0.2em] text-sm hover:scale-[1.02] active:scale-95 transition-all chamfer glow-yellow\" data-kid=\"1-6-1-1-1-1-3-3-1\">\n                                    Ejecutar Solicitud de Acceso\n                                </button>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n                <div class=\"hidden lg:block relative scanning-line\" data-kid=\"1-6-1-1-2\" data-name=\"form image scanning container\">\n                    <img alt=\"Futuristic sneakers\" class=\"w-full h-full object-cover grayscale brightness-50 contrast-125\" data-kid=\"1-6-1-1-2-1\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1545262901-16886dd24850?auto=format&w=800&q=80&fit=crop\"/>\n                    <div class=\"absolute inset-0 bg-[#FDEE00]/5 mix-blend-overlay\" data-kid=\"1-6-1-1-2-2\">\n                    </div>\n                    <div class=\"absolute bottom-0 left-0 w-full p-12 bg-gradient-to-t from-black to-transparent\" data-kid=\"1-6-1-1-2-3\">\n                        <div class=\"font-mono text-[10px] text-white/40 space-y-1\" data-kid=\"1-6-1-1-2-3-1\">\n                            <div data-kid=\"1-6-1-1-2-3-1-1\">\n                                // SNEAKER_CALIBRATION: STABLE\n                            </div>\n                            <div data-kid=\"1-6-1-1-2-3-1-2\">\n                                // GRIP_FACTOR: OPTIMAL\n                            </div>\n                            <div data-kid=\"1-6-1-1-2-3-1-3\">\n                                // KINETIC_ENERGY_HARVEST: 94%\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Footer -->\n    <footer class=\"py-20 border-t border-white/5 bg-[#0A0A0A]\" data-kid=\"1-7\">\n        <div class=\"max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-10\" data-kid=\"1-7-1\">\n            <div class=\"flex items-center gap-4\" data-kid=\"1-7-1-1\">\n                <div class=\"w-8 h-8 border border-[#FDEE00] flex items-center justify-center bg-[#FDEE00]/10 chamfer\" data-kid=\"1-7-1-1-1\">\n                    <span class=\"text-[#FDEE00] font-black text-[10px]\" data-kid=\"1-7-1-1-1-1\">\n                        ALC\n                    </span>\n                </div>\n                <span class=\"font-space font-bold text-lg uppercase tracking-tighter\" data-kid=\"1-7-1-1-2\">\n                    American Latin Class\n                </span>\n            </div>\n            <div class=\"flex gap-12 font-mono text-[10px] text-white/20 uppercase tracking-[0.2em]\" data-kid=\"1-7-1-2\">\n                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-2-1\" href=\"#\">\n                    Legal_Notice\n                </a>\n                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-2-2\" href=\"#\">\n                    Privacy_Protocol\n                </a>\n                <a class=\"hover:text-white transition-colors\" data-kid=\"1-7-1-2-3\" href=\"#\">\n                    System_Audit\n                </a>\n            </div>\n            <div class=\"text-white/40 text-xs font-mono\" data-kid=\"1-7-1-3\">\n                © 2026_GRID_OPERATIONS // ALL_RIGHTS_SYNCED\n            </div>\n        </div>\n    </footer>\n</div>\n",
      "comments": [],
      "created": "2026-07-21T20:41:14.115741+00:00",
