    "var_91986f1bcb66": {
      "type": "variant",
      "label": "Amber Hologram (Variant 2)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 3080,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;700;900&family=IBM+Plex+Sans:wght@300;400;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg-slate: #2A3439;\n    --bg-deep: #1A1F23;\n    --panel-graphite: #343434;\n    --amber-gold: #FFD800;\n    --amber-glow: rgba(255, 216, 0, 0.15);\n    --glass-border: rgba(255, 255, 255, 0.1);\n    --glass-bg: rgba(255, 255, 255, 0.05);\n  }\n\n  body {\n    background-color: var(--bg-deep);\n    color: #FFFFFF;\n    font-family: 'IBM+Plex+Sans', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-heading { font-family: 'Inconsolata', monospace; }\n  \n  .glass-panel {\n    background: var(--glass-bg);\n    backdrop-filter: blur(12px);\n    border: 1px solid var(--glass-border);\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);\n  }\n\n  .amber-text-glow {\n    color: var(--amber-gold);\n    text-shadow: 0 0 10px rgba(255, 216, 0, 0.5);\n  }\n\n  .amber-border-glow {\n    border-color: var(--amber-gold);\n    box-shadow: 0 0 15px rgba(255, 216, 0, 0.3), inset 0 0 15px rgba(255, 216, 0, 0.1);\n  }\n\n  .spotlight {\n    background: radial-gradient(circle at 50% 40%, rgba(255, 216, 0, 0.12) 0%, transparent 60%);\n  }\n\n  .hero-video-mask {\n    mask-image: radial-gradient(circle at center, black 30%, transparent 70%);\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0px); }\n    50% { transform: translateY(-20px); }\n  }\n  .animate-float { animation: float 6s ease-in-out infinite; }\n\n  @keyframes shimmer {\n    0% { transform: translateX(-100%); }\n    100% { transform: translateX(100%); }\n  }\n  .shimmer-sweep::after {\n    content: '';\n    position: absolute;\n    top: 0; left: 0; width: 100%; height: 100%;\n    background: linear-gradient(90deg, transparent, rgba(255, 216, 0, 0.1), transparent);\n    animation: shimmer 3s infinite;\n  }\n\n  .cli-cursor::after {\n    content: '_';\n    animation: blink 1s step-end infinite;\n  }\n  @keyframes blink { 50% { opacity: 0; } }\n\n  .reflection {\n    mask-image: linear-gradient(to bottom, rgba(0,0,0,1), transparent);\n    transform: scaleY(-1);\n    opacity: 0.2;\n  }\n</style>\n<div class=\"relative min-h-screen spotlight\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- Nav -->\n    <nav class=\"fixed top-0 left-0 w-full z-50 glass-panel border-b border-white/5 py-4 px-8 flex justify-between items-center\" data-kid=\"1-1\" data-name=\"navigation bar\">\n        <div class=\"flex items-center gap-3\" data-kid=\"1-1-1\" data-name=\"brand logo container\">\n            <div class=\"w-10 h-10 amber-border-glow border flex items-center justify-center font-heading font-bold text-xl text-[var(--amber-gold)] bg-black/20 rounded-sm\" data-kid=\"1-1-1-1\" data-name=\"brand icon\">\n                ALC\n            </div>\n            <span class=\"font-heading font-bold tracking-widest text-sm opacity-80\" data-kid=\"1-1-1-2\" data-name=\"brand system identifier text\">\n                SYSTEM // ALC_v2.0\n            </span>\n        </div>\n        <div class=\"hidden md:flex gap-10 font-heading text-sm font-bold uppercase tracking-wider\" data-kid=\"1-1-2\" data-name=\"navigation link group\">\n            <a class=\"hover:text-[var(--amber-gold)] transition-colors\" data-kid=\"1-1-2-1\" data-name=\"programs link\" href=\"#programs\">\n                Programs\n            </a>\n            <a class=\"hover:text-[var(--amber-gold)] transition-colors\" data-kid=\"1-1-2-2\" data-name=\"grid nodes link\" href=\"#branches\">\n                Grid Nodes\n            </a>\n            <a class=\"hover:text-[var(--amber-gold)] transition-colors\" data-kid=\"1-1-2-3\" data-name=\"initialize link\" href=\"#enroll\">\n                Initialize\n            </a>\n        </div>\n        <div class=\"flex items-center gap-6\" data-kid=\"1-1-3\" data-name=\"access terminal action container\">\n            <a class=\"px-5 py-2 amber-border-glow border border-[var(--amber-gold)] text-[var(--amber-gold)] font-heading text-xs font-bold uppercase tracking-tighter hover:bg-[var(--amber-gold)] hover:text-black transition-all\" data-kid=\"1-1-3-1\" data-name=\"access terminal link\" href=\"/login\">\n                Access Terminal\n            </a>\n        </div>\n    </nav>\n    <!-- Hero Section -->\n    <section class=\"relative min-h-screen pt-32 pb-20 flex flex-col items-center justify-center overflow-hidden\" data-kid=\"1-2\" data-name=\"hero section\">\n        <!-- Spotlight & Video -->\n        <div class=\"absolute inset-0 z-0\" data-kid=\"1-2-1\" data-name=\"hero background video container\">\n            <video autoplay=\"\" class=\"w-full h-full object-cover opacity-40 hero-video-mask grayscale contrast-125\" data-kid=\"1-2-1-1\" data-name=\"hero background video\" loop=\"\" muted=\"\" playsinline=\"\" poster=\"https://images.pexels.com/videos/7672380/abstract-accomplishment-achievement-adult-7672380.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" preload=\"metadata\" src=\"https://videos.pexels.com/video-files/7672380/7672380-uhd_3840_2160_25fps.mp4\">\n            </video>\n        </div>\n        <!-- Floating Cards -->\n        <div class=\"absolute top-1/4 left-20 z-10 glass-panel p-4 w-56 animate-float\" data-kid=\"1-2-2\" data-name=\"system status floating card\" style=\"animation-delay: 0s;\">\n            <div class=\"flex justify-between items-center mb-2\" data-kid=\"1-2-2-1\" data-name=\"card header container\">\n                <span class=\"font-heading text-[10px] opacity-60 uppercase\" data-kid=\"1-2-2-1-1\" data-name=\"status label text\">\n                    System Status\n                </span>\n                <div class=\"w-2 h-2 rounded-full bg-[var(--amber-gold)] animate-pulse\" data-kid=\"1-2-2-1-2\" data-name=\"status pulse indicator\">\n                </div>\n            </div>\n            <div class=\"font-heading text-sm amber-text-glow\" data-kid=\"1-2-2-2\" data-name=\"active nodes count text\">\n                ACTIVE_NODES: 05\n            </div>\n            <div class=\"w-full bg-white/10 h-1 mt-2 rounded-full overflow-hidden\" data-kid=\"1-2-2-3\" data-name=\"progress bar container\">\n                <div class=\"bg-[var(--amber-gold)] h-full w-[85%]\" data-kid=\"1-2-2-3-1\" data-name=\"progress bar indicator\">\n                </div>\n            </div>\n        </div>\n        <div class=\"absolute bottom-1/4 right-20 z-10 glass-panel p-4 w-64 animate-float\" data-kid=\"1-2-3\" data-name=\"synchronization log floating card\" style=\"animation-delay: -3s;\">\n            <div class=\"font-heading text-[10px] opacity-60 uppercase mb-2\" data-kid=\"1-2-3-1\" data-name=\"log header text\">\n                Synchronization Log\n            </div>\n            <div class=\"space-y-1 font-heading text-[10px] text-white/70\" data-kid=\"1-2-3-2\" data-name=\"log entries container\">\n                <div data-kid=\"1-2-3-2-1\" data-name=\"log entry 1\">\n                    > MATRIZ: SYNCED\n                </div>\n                <div data-kid=\"1-2-3-2-2\" data-name=\"log entry 2\">\n                    > NORTH_NODE: SYNCED\n                </div>\n                <div data-kid=\"1-2-3-2-3\" data-name=\"log entry 3\">\n                    > SOUTH_NODE: CALIBRATING...\n                </div>\n            </div>\n        </div>\n        <!-- Hero Content -->\n        <div class=\"relative z-20 text-center max-w-4xl px-4\" data-kid=\"1-2-4\" data-name=\"hero content container\">\n            <h1 class=\"font-heading text-7xl md:text-9xl font-black uppercase leading-none tracking-tighter mb-6\" data-kid=\"1-2-4-1\" data-name=\"hero headline text\">\n                <span class=\"block\" data-kid=\"1-2-4-1-1\" data-name=\"headline line 1\">\n                    Sync Your\n                </span>\n                <span class=\"block text-[var(--amber-gold)] amber-text-glow\" data-kid=\"1-2-4-1-2\" data-name=\"headline line 2 with glow\">\n                    Movement\n                </span>\n            </h1>\n            <p class=\"text-xl md:text-2xl font-light text-white/70 max-w-2xl mx-auto mb-10 leading-relaxed\" data-kid=\"1-2-4-2\" data-name=\"hero description text\">\n                Step into the elite grid of urban and tropical movement. Centralized management for the next generation of dancers.\n            </p>\n            <div class=\"flex flex-col md:flex-row gap-6 justify-center\" data-kid=\"1-2-4-3\" data-name=\"hero call to action button group\">\n                <button class=\"px-10 py-4 bg-[var(--amber-gold)] text-black font-heading font-black text-lg uppercase tracking-wider hover:scale-105 transition-transform\" data-kid=\"1-2-4-3-1\" data-name=\"primary initialization button\">\n                    Initialize Protocol\n                </button>\n                <button class=\"px-10 py-4 border border-white/20 glass-panel font-heading font-bold text-lg uppercase tracking-wider hover:border-[var(--amber-gold)] transition-colors\" data-kid=\"1-2-4-3-2\" data-name=\"secondary core modules button\">\n                    Core Modules\n                </button>\n            </div>\n        </div>\n        <!-- Proportional Metrics -->\n        <div class=\"relative z-20 mt-24 w-full max-w-6xl px-4 grid grid-cols-2 md:grid-cols-4 items-end gap-4\" data-kid=\"1-2-5\" data-name=\"metrics grid container\">\n            <div class=\"glass-panel p-6 flex flex-col items-center justify-end h-40 border-b-4 border-[var(--amber-gold)]\" data-kid=\"1-2-5-1\" data-name=\"active nodes metric card\">\n                <span class=\"font-heading text-5xl font-black amber-text-glow\" data-kid=\"1-2-5-1-1\" data-name=\"active nodes count\">\n                    05\n                </span>\n                <span class=\"font-heading text-xs uppercase opacity-60 tracking-widest mt-2\" data-kid=\"1-2-5-1-2\" data-name=\"active nodes label\">\n                    Active Nodes\n                </span>\n            </div>\n            <div class=\"glass-panel p-6 flex flex-col items-center justify-end h-32 border-b-4 border-white/20\" data-kid=\"1-2-5-2\" data-name=\"dance lines metric card\">\n                <span class=\"font-heading text-4xl font-black\" data-kid=\"1-2-5-2-1\" data-name=\"dance lines count\">\n                    03\n                </span>\n                <span class=\"font-heading text-xs uppercase opacity-60 tracking-widest mt-2\" data-kid=\"1-2-5-2-2\" data-name=\"dance lines label\">\n                    Dance Lines\n                </span>\n            </div>\n            <div class=\"glass-panel p-6 flex flex-col items-center justify-end h-48 border-b-4 border-[var(--amber-gold)]\" data-kid=\"1-2-5-3\" data-name=\"style protocols metric card\">\n                <span class=\"font-heading text-6xl font-black amber-text-glow\" data-kid=\"1-2-5-3-1\" data-name=\"style protocols count\">\n                    12+\n                </span>\n                <span class=\"font-heading text-xs uppercase opacity-60 tracking-widest mt-2\" data-kid=\"1-2-5-3-2\" data-name=\"style protocols label\">\n                    Style Protocols\n                </span>\n            </div>\n            <div class=\"glass-panel p-6 flex flex-col items-center justify-end h-36 border-b-4 border-white/20\" data-kid=\"1-2-5-4\" data-name=\"skill levels metric card\">\n                <span class=\"font-heading text-4xl font-black text-white/50\" data-kid=\"1-2-5-4-1\" data-name=\"skill levels value\">\n                    B1-B2\n                </span>\n                <span class=\"font-heading text-xs uppercase opacity-60 tracking-widest mt-2\" data-kid=\"1-2-5-4-2\" data-name=\"skill levels label\">\n                    Skill Levels\n                </span>\n            </div>\n        </div>\n    </section>\n    <!-- Programs Section (Bento Grid) -->\n    <section class=\"