tline-none w-full text-white placeholder-white/10 uppercase tracking-widest focus:amber-text-glow transition-all\" data-kid=\"1-5-1-3-2-2-2\" data-name=\"email address input\" placeholder=\"ENTER EMAIL ADDRESS\" type=\"email\"/>\n                    </div>\n                </div>\n                <div class=\"group\" data-kid=\"1-5-1-3-3\" data-name=\"node selection field group\">\n                    <div class=\"text-white/40 text-sm uppercase tracking-tighter mb-2\" data-kid=\"1-5-1-3-3-1\" data-name=\"field label\">\n                        03_NODE_SELECTION:\n                    </div>\n                    <div class=\"flex items-center gap-4\" data-kid=\"1-5-1-3-3-2\" data-name=\"field input container\">\n                        <span class=\"text-[var(--amber-gold)]\" data-kid=\"1-5-1-3-3-2-1\" data-name=\"field input prompt\">\n                            >\n                        </span>\n                        <select class=\"bg-transparent border-none outline-none w-full text-white uppercase tracking-widest appearance-none cursor-pointer focus:amber-text-glow transition-all\" data-kid=\"1-5-1-3-3-2-2\" data-name=\"node select dropdown\">\n                            <option class=\"bg-[#1A1F23]\" data-kid=\"1-5-1-3-3-2-2-1\" data-name=\"dropdown option 1\">\n                                SELECT SECTOR NODE\n                            </option>\n                            <option class=\"bg-[#1A1F23]\" data-kid=\"1-5-1-3-3-2-2-2\" data-name=\"dropdown option 2\">\n                                MATRIZ_HUB\n                            </option>\n                            <option class=\"bg-[#1A1F23]\" data-kid=\"1-5-1-3-3-2-2-3\" data-name=\"dropdown option 3\">\n                                NORTH_NODE\n                            </option>\n                            <option class=\"bg-[#1A1F23]\" data-kid=\"1-5-1-3-3-2-2-4\" data-name=\"dropdown option 4\">\n                                SOUTH_SECTOR\n                            </option>\n                        </select>\n                    </div>\n                </div>\n                <div class=\"group\" data-kid=\"1-5-1-3-4\" data-name=\"protocol interest field group\">\n                    <div class=\"text-white/40 text-sm uppercase tracking-tighter mb-2\" data-kid=\"1-5-1-3-4-1\" data-name=\"field label\">\n                        04_PROTOCOL_INTEREST:\n                    </div>\n                    <div class=\"flex items-center gap-4\" data-kid=\"1-5-1-3-4-2\" data-name=\"field input container\">\n                        <span class=\"text-[var(--amber-gold)]\" data-kid=\"1-5-1-3-4-2-1\" data-name=\"field input prompt\">\n                            >\n                        </span>\n                        <input class=\"bg-transparent border-none outline-none w-full text-white placeholder-white/10 uppercase tracking-widest focus:amber-text-glow transition-all\" data-kid=\"1-5-1-3-4-2-2\" data-name=\"protocol interest input\" placeholder=\"SALSA / HIP HOP / HEELS\" type=\"text\"/>\n                    </div>\n                </div>\n                <div class=\"pt-8\" data-kid=\"1-5-1-3-5\" data-name=\"form submission group\">\n                    <button class=\"w-full py-5 bg-[var(--amber-gold)] text-black font-black uppercase tracking-[0.2em] hover:shadow-[0_0_30px_rgba(255,216,0,0.4)] transition-all flex items-center justify-center gap-3\" data-kid=\"1-5-1-3-5-1\" data-name=\"submit button\" type=\"submit\">\n                        <span data-kid=\"1-5-1-3-5-1-1\" data-name=\"submit button label\">\n                            Execute_Enrollment\n                        </span>\n                        <i class=\"ti ti-arrow-right text-2xl\" data-kid=\"1-5-1-3-5-1-2\" data-name=\"submit arrow icon\">\n                        </i>\n                    </button>\n                    <div class=\"mt-4 text-[10px] text-center opacity-30 uppercase font-heading tracking-widest cli-cursor\" data-dynamic=\"true\" data-kid=\"1-5-1-3-5-2\" data-name=\"terminal status cursor text\" data-reason=\"text appended with blinking cursor animation\">\n                        Waiting for user input...\n                    </div>\n                </div>\n            </form>\n        </div>\n    </section>\n    <!-- Footer -->\n    <footer class=\"py-12 px-8 glass-panel border-t border-white/5 bg-black/40\" data-kid=\"1-6\" data-name=\"footer bar\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"1-6-1\" data-name=\"footer container\">\n            <div class=\"flex items-center gap-4\" data-kid=\"1-6-1-1\" data-name=\"footer brand group\">\n                <div class=\"w-8 h-8 border border-[var(--amber-gold)] text-[var(--amber-gold)] flex items-center justify-center font-heading font-bold text-sm\" data-kid=\"1-6-1-1-1\" data-name=\"footer brand icon\">\n                    ALC\n                </div>\n                <div class=\"font-heading text-xs uppercase tracking-widest opacity-60\" data-kid=\"1-6-1-1-2\" data-name=\"footer brand name and description\">\n                    American Latin Class // Global Movement Grid\n                </div>\n            </div>\n            <div class=\"flex gap-8 font-heading text-[10px] font-bold uppercase tracking-widest opacity-40\" data-kid=\"1-6-1-2\" data-name=\"footer utility links\">\n                <span data-kid=\"1-6-1-2-1\" data-name=\"footer copyright notice\">\n                    © 2026_SYSTEMS\n                </span>\n                <span data-kid=\"1-6-1-2-2\" data-name=\"footer location tag\">\n                    Lat: -0.1807 / Lng: -78.4678\n                </span>\n                <span data-kid=\"1-6-1-2-3\" data-name=\"footer security status text\">\n                    Secure Terminal\n                </span>\n            </div>\n            <div class=\"flex gap-4\" data-kid=\"1-6-1-3\" data-name=\"footer social media links\">\n                <a class=\"w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:amber-border-glow transition-all\" data-kid=\"1-6-1-3-1\" data-name=\"social link instagram\" href=\"#\">\n                    <i class=\"ti ti-brand-instagram\" data-kid=\"1-6-1-3-1-1\" data-name=\"instagram icon\">\n                    </i>\n                </a>\n                <a class=\"w-8 h-8 rounded-full border border-white/10 flex items-center justify-center hover:amber-border-glow transition-all\" data-kid=\"1-6-1-3-2\" data-name=\"social link twitter\" href=\"#\">\n                    <i class=\"ti ti-brand-twitter\" data-kid=\"1-6-1-3-2-1\" data-name=\"twitter icon\">\n                    </i>\n                </a>\n            </div>\n        </div>\n    </footer>\n</div>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\">\n</script>\n<script>\n    window.addEventListener('load', () => {\n    // Holographic Reveal\n    gsap.from('.glass-panel', {\n      opacity: 0,\n      y: 30,\n      duration: 1.2,\n      stagger: 0.1,\n      ease: 'power3.out',\n      delay: 0.5\n    });\n\n    gsap.from('h1 span', {\n      opacity: 0,\n      x: -50,\n      duration: 1,\n      stagger: 0.3,\n      ease: 'power4.out',\n      delay: 0.2\n    });\n\n    // Hover glow effect for cards\n    const cards = document.querySelectorAll('.glass-panel');\n    cards.forEach(card => {\n      card.addEventListener('mouseenter', () => {\n        gsap.to(card, {\n          borderColor: 'rgba(255, 216, 0, 0.4)',\n          boxShadow: '0 0 20px rgba(255, 216, 0, 0.2)',\n          duration: 0.4\n        });\n      });\n      card.addEventListener('mouseleave', () => {\n        gsap.to(card, {\n          borderColor: 'rgba(255, 255, 255, 0.1)',\n          boxShadow: '0 8px 32px 0 rgba(0, 0, 0, 0.3)',\n          duration: 0.4\n        });\n      });\n    });\n  });\n</script>\n",
