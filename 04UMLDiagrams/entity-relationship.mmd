  TEACHER o|--o{ TEACHER_ATTENDANCE_RECORD : works
  CLASS_SESSION o|--o{ TEACHER_ATTENDANCE_RECORD : includes
  STUDENT_ATTENDANCE_RECORD o|--o{ ABSENCE_JUSTIFICATION : explains
  USER o|--o{ ABSENCE_JUSTIFICATION : reviews
  STUDENT o|--o{ SCHOLARSHIP_EVALUATION : evaluated
  STUDENT o|--o{ LEVEL_PROMOTION_EVALUATION : promoted
  USER o|--o{ SCHOLARSHIP_EVALUATION : evaluates
  USER o|--o{ LEVEL_PROMOTION_EVALUATION : evaluates
