      "name": "Health",
      "item": [
        {
          "name": "Analytics Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('service is healthy', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data.status).to.eql('healthy');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{analytics_base_url}}/health",
              "host": [
                "{{analytics_base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication Proof",
      "item": [
        {
          "name": "Student Attendance Risk - No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 401 without token', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('request is rejected', function () {",
                  "  pm.expect(body.success).to.eql(false);",
                  "  pm.expect(body.message).to.match(/Authentication required|Invalid session token/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
