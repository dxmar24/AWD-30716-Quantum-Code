{
  "info": {
    "_postman_id": "89119ee1-20d5-4e6d-8f60-9b2a23ca34b1",
    "name": "American Latin Class API",
    "description": "Manual verification collection for the American Latin Class Attendance System. Run against AWS with a real Google ID token and a Postman cookie jar session. New Google users start as Student; promote the user in the database before running admin/director folders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{session_token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth & Session",
      "item": [
        {
          "name": "Auth Config",
          "request": { "method": "GET", "url": "{{base_url}}/auth/config" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));", "pm.test('Google client id returned', () => pm.expect(pm.response.json().data.googleClientId).to.be.a('string'));"] } }]
        },
        {
          "name": "Private Dashboard - Anonymous Redirect",
          "request": { "method": "GET", "url": "{{site_url}}/private/dashboard.html" },
          "protocolProfileBehavior": { "followRedirects": false },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 302 without session', () => pm.response.to.have.status(302));", "pm.test('Redirects to login', () => pm.expect(pm.response.headers.get('Location')).to.include('/login.html?session=expired'));"] } }]
        },
        {
          "name": "Google Login - Invalid Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idToken\": \"not-a-valid-google-token\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/auth/google"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 401', () => pm.response.to.have.status(401));"] } }]
        },
        {
          "name": "Google Login - Real Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idToken\": \"{{google_id_token}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{base_url}}/auth/google"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.environment.set('user_id', json.data.user.id);", "pm.environment.set('session_token', json.data.sessionToken);", "pm.test('JWT session token returned', () => pm.expect(json.data.sessionToken.split('.')).to.have.length(3));", "pm.test('Bearer token type returned', () => pm.expect(json.data.tokenType).to.eql('Bearer'));", "pm.test('Session cookie issued', () => pm.expect(pm.cookies.has('alc_session')).to.be.true);"] } }]
        },
        {
          "name": "Current Session",
          "request": { "method": "GET", "url": "{{base_url}}/auth/me" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.environment.set('user_id', json.data.user.id);"] } }]
        },
        {
          "name": "Current Session - Bearer Token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{session_token}}" }],
            "url": "{{base_url}}/auth/me"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200 with bearer token', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.test('Session user returned', () => pm.expect(json.data.user.id).to.eql(pm.environment.get('user_id')));"] } }]
        },
        {
          "name": "Private Dashboard - With Session",
          "request": { "method": "GET", "url": "{{site_url}}/private/dashboard.html" },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200 with session', () => pm.response.to.have.status(200));", "pm.test('React root present', () => pm.expect(pm.response.text()).to.include('id=\"root\"'));"] } }]
        }
      ]
    },
