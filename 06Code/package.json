{
  "name": "american-latin-class-attendance-system",
  "version": "1.0.0",
  "description": "Academic-professional attendance and academic tracking backend for American Latin Class.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "frontend:dev": "vite --host 0.0.0.0",
    "frontend:build": "vite build",
    "db:smoke:prisma": "node scripts/prisma-smoke.js",
    "test:api:validation": "node scripts/api-validation-suite.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "^4.22.2",
    "express-rate-limit": "7.5.0",
    "google-auth-library": "^10.7.0",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "pg": "8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "vite": "^5.4.21"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
