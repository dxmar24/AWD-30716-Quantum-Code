{
  "name": "american-latin-class-attendance-system",
  "version": "1.0.0",
  "description": "Academic-professional attendance and academic tracking backend for American Latin Class.",
  "main": "backend/src/server.js",
  "scripts": {
    "prestart": "npm run frontend:build",
    "start": "node backend/src/server.js",
    "predev": "npm run frontend:build",
    "dev": "node backend/src/server.js",
    "db:local:up": "docker compose up -d postgres mailpit",
    "db:local:down": "docker compose down",
    "db:local:logs": "docker compose logs -f postgres mailpit",
    "db:generate": "prisma generate --schema persistence/prisma/schema.prisma",
    "db:studio": "prisma studio --schema persistence/prisma/schema.prisma",
    "db:migrate": "node scripts/apply-migrations.js",
    "db:migrate:status": "node scripts/apply-migrations.js --status",
    "db:bootstrap-admin": "node scripts/bootstrap-admin.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "frontend:dev": "vite --host 127.0.0.1",
    "frontend:build": "node scripts/build-frontend.js",
    "db:smoke:prisma": "node scripts/prisma-smoke.js",
    "db:smoke:operational": "node scripts/prisma-operational-smoke.js",
    "db:seed:business-rules": "node scripts/seed-business-rule-demo-data.js",
    "db:seed:real-verification": "node scripts/seed-real-verification-data.js",
    "db:seed:role-test": "node scripts/seed-role-test-data.js",
    "db:seed:academic-demo": "node scripts/seed-academic-demo-data.js",
    "db:reset:defense": "node scripts/reset-defense-dataset.js",
    "db:normalize:levels": "node scripts/normalize-academic-levels.js",
    "postman:evidence:local": "node scripts/run-postman-local-evidence.js",
    "postman:evidence:analytics": "node scripts/run-python-analytics-postman-evidence.js",
    "postman:coverage": "node scripts/verify-postman-route-coverage.js",
    "test:api:validation": "node scripts/api-validation-suite.js",
    "evidence:ui": "node scripts/capture-ui-evidence.js",
    "diagrams:render": "node ../04UMLDiagrams/render-diagrams.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.6",
    "dotenv": "16.4.7",
    "express": "^4.22.2",
    "express-rate-limit": "7.5.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "2.2.0",
    "nodemailer": "9.0.3",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "jest": "^30.4.2",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "vite": "^7.3.6"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/backend/tests/setup-env.js"
    ],
    "testMatch": [
      "**/backend/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
