# Copy to .env locally. Never commit populated secrets or real account identifiers.
NODE_ENV=development
HOST=127.0.0.1
PORT=3000
FRONTEND_PORT=5173
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
# Optional, browser-restricted key for the official no-charge Maps Embed API.
# Without it, the landing page uses Google's embedded map viewer and Maps URLs.
VITE_GOOGLE_MAPS_API_KEY=
DB_DRIVER=prisma
DATABASE_URL=
ALLOW_IN_MEMORY_DB=false

SESSION_SECRET=
SESSION_TTL_MINUTES=120
JWT_ISSUER=american-latin-class-auth
JWT_AUDIENCE=american-latin-class-services
GOOGLE_CLIENT_ID=
ALLOW_MOCK_GOOGLE_TOKENS=false
POSTMAN_LOGIN_ENABLED=false
POSTMAN_LOGIN_EMAIL=
POSTMAN_LOGIN_PASSWORD=
EXPOSE_SESSION_TOKEN=false

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false
COOKIE_SECURE=false
FORCE_HTTPS=false
AUTH_RATE_LIMIT_MAX=20
JSON_BODY_LIMIT_BYTES=102400
EVIDENCE_MAX_BYTES=5242880
TEACHER_HOURLY_RATE=12.50

# Analytics service. Authentication bypass is accepted only when NODE_ENV=test.
ANALYTICS_AUTH_REQUIRED=true
ANALYTICS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ANALYTICS_SERVICE_NAME=American Latin Class Analytics API

# Local PostgreSQL container secret (required by docker compose).
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# One-time production bootstrap. Remove these immediately after the first Admin is created.
BOOTSTRAP_ADMIN_CONFIRM=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_NAME=
BOOTSTRAP_ADMIN_PASSWORD=

# Destructive/demo seeds: development + localhost database + explicit opt-in only.
ALLOW_LOCAL_DEMO_SEEDS=false
SEED_ADMIN_EMAIL=
SEED_GENERAL_DIRECTOR_EMAIL=
SEED_BRANCH_DIRECTOR_EMAIL=
SEED_BRANCH_DIRECTOR_NORTH_EMAIL=
SEED_BRANCH_DIRECTOR_CENTRAL_EMAIL=
SEED_TEACHER_EMAIL=
SEED_STUDENT_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_GENERAL_DIRECTOR_PASSWORD=
SEED_BRANCH_DIRECTOR_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_STUDENT_PASSWORD=
SEED_VERIFICATION_ADMIN_PASSWORD=
# Account invitation delivery. Use Mailpit locally and a transactional SMTP
# provider in staging/production.
EMAIL_TRANSPORT=smtp
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=American Latin Class <no-reply@americanlatinclass.ec>
APP_PUBLIC_URL=http://127.0.0.1:3005
